    "   \"source\": [\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import os, sys\\n\",\n",
    "    \"import polars as pl\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"sys.path.insert(0, os.path.abspath(\\\"..\\\"))\\n\",\n",
