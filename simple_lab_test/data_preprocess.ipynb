    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"intermittent_parts = result.filter(pl.col('demand_type') == 'intermittent').select('oper_part_no').unique()\\n\",\n",
    "    \"intermittent_df = out.join(intermittent_parts, on = 'oper_part_no', how = 'right')\\n\",\n",
    "    \"\\n\",\n",
    "    \"pdf = intermittent_df.to_pandas()\\n\",\n",
    "    \"pdf = pdf.sort_values(['oper_part_no', 'seq'])\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize = (18, 7))\\n\",\n",
    "    \"for part, g in pdf.groupby('oper_part_no', sort = False):\\n\",\n",
    "    \"    ax.plot(g['seq'].values, g['demand_qty'].values, linewidth = 1, alpha = 0.25)\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax.set_title('Demand Qty by oper_part_no (all parts)')\\n\",\n",
    "    \"ax.set_xlabel('seq')\\n\",\n",
    "    \"ax.set_ylabel('demand_qty')\\n\",\n",
    "    \"ax.grid(True, alpha = 0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
