    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Select Intermittent Parts using intermittent detector.\",\n",
    "   \"id\": \"d201519807970f44\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-26T03:26:59.754559Z\",\n",
    "     \"start_time\": \"2026-02-26T03:26:59.542314Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from utils.intermittent_detector import IntermittentConfig, IntermittentDetector\\n\",\n",
    "    \"\\n\",\n",
    "    \"intermittent_config = IntermittentConfig(\\n\",\n",
    "    \"    id_col = 'oper_part_no',\\n\",\n",
    "    \"    date_col = 'demand_dt',\\n\",\n",
    "    \"    y_col = 'demand_qty',\\n\",\n",
    "    \"    seq_col = 'seq',\\n\",\n",
    "    \"    adi_threshold = 1.32,\\n\",\n",
    "    \"    cv2_threshold = 0.49,\\n\",\n",
    "    \"    epsilon = 0.0,\\n\",\n",
    "    \"    min_periods = 10,\\n\",\n",
    "    \"    no_demand_label = 'no_demand',\\n\",\n",
    "    \"    insufficient_label = 'insufficient'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"result = IntermittentDetector(\\n\",\n",
    "    \"    freq = 'weekly',\\n\",\n",
    "    \"    config = intermittent_config,\\n\",\n",
    "    \").run(df = out, return_stats = True )\\n\",\n",
