    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Making Marker DataFrame\",\n",
    "   \"id\": \"cdb9440ceef87e31\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-26T03:45:15.673031Z\",\n",
    "     \"start_time\": \"2026-02-26T03:45:15.621976Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def make_marks_intermittent(df: pl.DataFrame, K: int = 12, p1: float = 0.99, p2: float = 0.999) -> pl.DataFrame:\\n\",\n",
    "    \"    assert K >= 6\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # event 생성\\n\",\n",
    "    \"    ev = (\\n\",\n",
    "    \"        df.filter(pl.col('demand_qty') > 0) # 0 이상인것들만\\n\",\n",
    "    \"          .sort(['oper_part_no', 'seq'])\\n\",\n",
    "    \"          .with_columns([\\n\",\n",
    "    \"              pl.col('demand_qty').log1p().alias('z'),\\n\",\n",
    "    \"             (pl.col('seq') - pl.col('seq').shift(1).over('oper_part_no'))\\n\",\n",
    "    \"                .fill_null(0)\\n\",\n",
    "    \"                .cast(pl.Int32)\\n\",\n",
    "    \"                .alias('delta_t'),\\n\",\n",
    "    \"        ])\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    q1 = ev.select(pl.col(\\\"demand_qty\\\").quantile(p1, \\\"nearest\\\").alias(\\\"q1\\\")).item()\\n\",\n",
    "    \"    q2 = ev.select(pl.col(\\\"demand_qty\\\").quantile(p2, \\\"nearest\\\").alias(\\\"q2\\\")).item()\\n\",\n",
    "    \"    base = ev.filter(pl.col('demand_qty') <= q1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    n_base_bins = K - 2\\n\",\n",
    "    \"    cut_probs = [i / n_base_bins for i in range(1, n_base_bins)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    q_expr = [\\n\",\n",
    "    \"        pl.col(\\\"z\\\").quantile(p, \\\"nearest\\\").alias(f\\\"q_{i:02d}\\\")\\n\",\n",
    "    \"        for i, p in enumerate(cut_probs, start=1)\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # base가 너무 작거나(이벤트 부족) cuts가 비는 경우를 대비\\n\",\n",
    "    \"    if base.height == 0:\\n\",\n",
    "    \"        cuts = []\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        row = base.select(q_expr).row(0)\\n\",\n",
    "    \"        cuts = sorted(set(float(x) for x in row if x is not None))\\\\\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # z -> base_bin (0..n_base_bins-1)\\n\",\n",
    "    \"    expr = None\\n\",\n",
    "    \"    for i, c in enumerate(cuts):\\n\",\n",
    "    \"        if expr is None:\\n\",\n",
    "    \"            expr = pl.when(pl.col('z') <= c).then(i)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            expr = expr.when(pl.col('z') <= c).then(i)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    base_bin = (pl.lit(0) if expr is None else expr.otherwise(len(cuts))).clip(0, n_base_bins - 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    out = ev.with_columns(\\n\",\n",
    "    \"        pl.when(pl.col('demand_qty') <= q1)\\n\",\n",
    "    \"          .then(base_bin)\\n\",\n",
    "    \"          .when(pl.col('demand_qty') <= q2)\\n\",\n",
    "    \"          .then(pl.lit(K-2))\\n\",\n",
    "    \"          .otherwise(pl.lit(K-1))\\n\",\n",
    "    \"          .cast(pl.Int32)\\n\",\n",
    "    \"          .alias('mark')\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return out.select(['oper_part_no', 'demand_dt', 'seq', 'delta_t', 'demand_qty', 'z', 'mark'])\\n\",\n",
    "    \"\\n\",\n",
    "    \"marked_df = make_marks_intermittent(intermittent_df, K=8, p1=0.99, p2=0.999)\\n\",\n",
    "    \"\\n\",\n",
    "    \"marked_df.group_by(\\\"mark\\\").len().sort(\\\"mark\\\")\\n\",\n",
    "    \"marked_df.select(pl.col(\\\"delta_t\\\")).describe()\"\n",
    "   ],\n",
